@page
@model IndexModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Login";
}

<div class="login-page">
    <header class="login-topbar">
        <div class="login-topbar-left">DeSales University Code Jam</div>
    </header>

    <div class="login-center-wrap">
        <div class="login-center">
            <p class="login-welcome">
                Welcome to the Annual Code Jam Hosted by DeSales University.
                Please select your team in the drop down menu below and input the code you have been assigned.
            </p>

            <form method="post" class="login-form">
                <div class="login-row">
                    <div class="login-label mono">Team</div>
                    <select asp-for="SelectedUser" class="login-input mono">
                        <option value="">Select Team</option>
                        <option value="Team1">Team1</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>

                <div class="login-row">
                    <div class="login-label mono">PASSWORD</div>
                    <input asp-for="Password" class="login-input mono" type="password" />
                </div>

                <button class="login-enter mono" type="submit">&gt;&gt; ENTER &lt;&lt;</button>

                <div asp-validation-summary="All" class="text-danger"></div>
            </form>
        </div>
    </div>
</div>