@page
@{
    ViewData["Title"] = "Submission";
}

<div class="team-page">

    <!-- TOP BAR -->
    <header class="team-topbar">
        <div class="team-topbar-left">&gt;&gt; TEAM 1</div>
    </header>

    <!-- CONTENT GRID -->
    <div class="container-fluid team-content">
        <div class="row g-3">

            <!-- LEFT COLUMN: SUBMISSION FORM -->
            <div class="col-12 col-lg-7">

                <section class="panel panel-tall">
                    <div class="panel-title">SUBMISSION</div>
                    <div class="panel-text red">
                        Choose the problem number and the tab you want to submit.
                        (Prototype UI — no backend logic yet.)
                    </div>

                    <div class="panel-body">

                        <div class="row g-3 mt-1">
                            <div class="col-12 col-md-6">
                                <label class="form-label submission-label">Problem #</label>
                                <input class="form-control submission-input" type="text" placeholder="e.g., 1" />
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label submission-label">Select Tab</label>
                                <select class="form-select submission-input">
                                    <option selected>Tab 1</option>
                                    <option>Tab 2</option>
                                    <option>Tab 3</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button class="btn team-btn-submit w-100" type="button">
                                - = &nbsp; SUBMIT TO JUDGES &nbsp; = -
                            </button>

                            <div class="text-muted mt-2 submission-note">
                                Submission bundle: Team #, Problem #, Selected Tab, Code from Tab (not implemented).
                            </div>
                        </div>

                        <!-- OPTIONAL: what gets sent (purely visual) -->
                        <div class="mt-4">
                            <div class="panel-title center" style="margin-bottom: 10px;">SUBMISSION PREVIEW</div>
                            <div class="mono-pre submission-preview">
TEAM: 1
PROBLEM: #
TAB: Tab #
TIMESTAMP: --:--:--

CODE:
[Code from selected tab will appear here]
                            </div>
                        </div>

                    </div>
                </section>
            </div>

            <!-- RIGHT COLUMN: SCOREBOARD -->
            <div class="col-12 col-lg-5">
                <section class="panel panel-scoreboard">
                    <div class="scoreboard-title">SCORE BOARD</div>
                    <div class="scoreboard-divider">========</div>

                    <div class="scoreboard-rows">
                        <div class="scoreboard-row highlight-yellow">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                        <div class="scoreboard-row">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                        <div class="scoreboard-row highlight-orange">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                        <div class="scoreboard-row">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                        <div class="scoreboard-row">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                        <div class="scoreboard-row">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                        <div class="scoreboard-row">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                        <div class="scoreboard-row">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                        <div class="scoreboard-row">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                        <div class="scoreboard-row">
                            TEAM NAME#1 | RANK # | POINT #
                        </div>
                    </div>

                    <div class="scoreboard-bottom-divider">+-+-+-+-+-+-+-+-+-+-+-+-+-+-</div>

                    <div class="scoreboard-time">
                        <div class="scoreboard-time-label">Current Time</div>
                        <div class="scoreboard-time-value">00:00</div>
                    </div>
                </section>
            </div>

        </div>
    </div>
</div>
