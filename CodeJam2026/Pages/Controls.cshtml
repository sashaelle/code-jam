@page
@model ControlsModel
@{
    ViewData["Title"] = "Controls";
    Layout = "_AppLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/controls.css" asp-append-version="true" />
}

<div class="controls-page">

    <!-- TOP BAR -->
    <header class="controls-header">
        <div class="controls-header-left">ADMIN OPTIONS/DEBUG</div>
        <div class="controls-header-right">
            <a class="app-navlink" asp-page="/Judge">&lt;&lt; BACK TO JUDGE</a>
            <span class="app-navsep">|</span>
            <a class="app-navlink" asp-page="/Scoreboard">SCOREBOARD</a>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container-fluid controls-content">
        <div class="row g-3">

            <!-- LEFT SIDE -->
            <div class="col-12 col-lg-7">
                <section class="controls-block controls-generate-block mb-4">
                    <form method="post" asp-page-handler="GenerateTeams" class="controls-generate-form">
                        <div class="controls-generate-input-wrap">
                            <label class="controls-generate-label mono" asp-for="TeamCount">Number of teams</label>
                            <input asp-for="TeamCount" class="controls-generate-input mono" type="number" min="1" max="100" />
                        </div>
                        <button class="btn app-btn controls-generate-btn" type="submit">Generate Teams</button>
                        <div asp-validation-summary="All" class="controls-generate-error mt-2"></div>
                    </form>
                    @if (!string.IsNullOrWhiteSpace(Model.GenerateTeamsStatusMessage))
                    {
                        <div class="controls-generate-success mt-2">@Model.GenerateTeamsStatusMessage</div>
                    }
                </section>

                <section class="controls-block controls-accounts-block mb-4">
                    <div class="controls-row controls-accounts-title-row mb-2">
                        <strong class="controls-accounts-title">Generated Team Accounts</strong>
                    </div>
                    @if (Model.TeamCredentials.Count == 0)
                    {
                        <div class="mono controls-accounts-empty">No team accounts found.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm controls-accounts-table">
                                <thead>
                                    <tr>
                                        <th scope="col">Username</th>
                                        <th scope="col">Password</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var account in Model.TeamCredentials)
                                    {
                                        <tr>
                                            <td class="mono">@account.Username</td>
                                            <td class="mono">@account.Password</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </section>

                @if (User.IsInRole("Admin"))
                {
                    <section class="controls-block controls-password-block mb-4">
                        <div class="controls-accounts-title-row mb-2">
                            <strong class="controls-accounts-title">Change Account Password</strong>
                        </div>

                        <form method="post" asp-page-handler="ChangePassword" class="controls-password-form">
                            <div class="controls-generate-input-wrap controls-password-input-wrap">
                                <label asp-for="SelectedAccountUsername" class="controls-generate-label mono">Account</label>
                                <select asp-for="SelectedAccountUsername" class="controls-generate-input controls-password-select mono">
                                    <option value="">-- Select account --</option>
                                    @foreach (var username in Model.AllAccountUsernames)
                                    {
                                        <option value="@username">@username</option>
                                    }
                                </select>
                            </div>

                            <div class="controls-generate-input-wrap controls-password-input-wrap">
                                <label asp-for="NewPassword" class="controls-generate-label mono">New password</label>
                                <input asp-for="NewPassword" class="controls-generate-input controls-password-input mono" type="text" autocomplete="new-password" />
                            </div>

                            <button class="btn app-btn controls-generate-btn controls-password-btn" type="submit">
                                Change Password
                            </button>

                            @if (!string.IsNullOrWhiteSpace(Model.ChangePasswordStatusMessage))
                            {
                                <div class="controls-generate-success controls-password-success">@Model.ChangePasswordStatusMessage</div>
                            }

                            <div asp-validation-summary="All" class="controls-generate-error mt-2"></div>
                        </form>
                    </section>
                }

            </div>

            <!-- CENTER DIVIDER -->
            <div class="d-none d-lg-flex col-lg-1 justify-content-center">
                <div class="controls-divider"></div>
            </div>

            <!-- RIGHT SIDE -->
            <div class="col-12 col-lg-4">
                <div class="controls-right-stack">
                    <button class="ctrl-big" type="button">HIDE SCOREBOARD</button>
                    <button class="ctrl-big" type="button">OPTION 1</button>
                    <button class="ctrl-big" type="button">OPTION 2</button>
                    <button class="ctrl-big" type="button">OPTION 3</button>
                    <button class="ctrl-big" type="button">CLEAR DATABASE</button>
                </div>

            </div>

        </div>
    </div>
</div>
