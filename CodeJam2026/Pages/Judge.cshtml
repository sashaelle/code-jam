@page
@model JudgeModel
@{
    ViewData["Title"] = "Judge";
    Layout = "_AppLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/judge.css" asp-append-version="true" />
}

<div class="judge-page">

    <!-- HEADER BAR -->
    <header class="judge-header">
        <div class="judge-header-left">JUDGE</div>
        
        <div class="judge-header-right">
            <a class="app-navlink" asp-page="/Scoreboard">Scoreboard</a>
            <span class="app-navsep">|</span>
            <a class="app-navlink" asp-page="/Controls">Controls</a>
        </div>
    </header>

    <!-- MAIN GRID -->
    <div class="container-fluid judge-content">
        <div class="row g-3">

            <!-- LEFT COLUMN -->
            <div class="col-12 col-lg-7">

                <!-- WRITTEN CODE INTERFACE -->
                <section class="judge-panel judge-panel-code">
                    <div class="judge-panel-title">Submission Code</div>
                    <div class="judge-panel-sub red">
                        This is the display for the code that the participants write.<br />
                        Sent
                    </div>

                    <textarea id="judge-code-box"
                                class="judge-code-box mono-pre"
                                spellcheck="false">
CODE WRITTEN BY TEAMS  CODE WRITTEN BY TEAMS

CODE WRITTEN BY TEAMS  CODE WRITTEN BY TEAMS

CODE WRITTEN BY TEAMS  CODE WRITTEN BY TEAMS

CODE WRITTEN BY TEAMS  CODE WRITTEN BY TEAMS

CODE WRITTEN BY TEAMS  CODE WRITTEN BY TEAMS
                    </textarea>
                </section>

                <!-- INPUT / OUTPUT WINDOW -->
                <section class="judge-panel judge-panel-io mt-3">
                    <div class="judge-panel-title">INPUT / OUTPUT WINDOW</div>
                    <div class="judge-panel-sub red">
                        This is the display for testing the code based on the used cases.
                    </div>

                    <div class="judge-panel-body mono-pre">
CODE OUTPUT  CODE OUTPUT  CODE OUTPUT

CODE OUTPUT  CODE OUTPUT  CODE OUTPUT

CODE OUTPUT  CODE OUTPUT  CODE OUTPUT
                    </div>
                </section>

            </div>

            <!-- RIGHT COLUMN -->
            <div class="col-12 col-lg-5">

                <!-- TEAM QUESTION SELECTION WINDOW -->
                <section class="judge-panel judge-panel-queue">
                    <div class="judge-panel-title">Team Question Selection Window</div>
                    <div class="judge-panel-sub red">
                        This is the display that the judges use to select the code that they are to test based on submission.
                    </div>

                    <div id="submissionQueue" class="judge-queue"></div>
                </section>

                <!-- FEEDBACK WINDOW -->
                <section class="judge-panel judge-panel-feedback mt-3">
                    <div class="judge-panel-title">FEEDBACK WINDOW</div>
                    <div class="judge-panel-sub red">
                        This is meant to allow the judges to type out recommendations and fixes to send to the participants.
                    </div>

                    <textarea class="judge-feedback mono-pre" rows="7" spellcheck="false">CODE REWORK CRITIQUE  CODE REWORK CRITIQUE

CODE REWORK CRITIQUE  CODE REWORK CRITIQUE

CODE REWORK CRITIQUE  CODE REWORK CRITIQUE</textarea>

                    <div class="row g-2 mt-3">
                        <div class="col-4">
                            <button id="judge-run-btn" class="btn app-btn w-100" type="button">Run</button>
                        </div>
                        <div class="col-4">
                            <button class="btn app-btn w-100" type="button">Score</button>
                        </div>
                        <div class="col-4">
                            <button class="btn app-btn w-100" type="button">Send</button>
                        </div>
                    </div>
                </section>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.judgeApiUrl = '@Url.Content("~/api/Judge")';
    </script>
    <script src="~/js/judge/judgeQueue.js" asp-append-version="true"></script>
}