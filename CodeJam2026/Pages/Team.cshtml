@page
@model TeamModel
@{
    ViewData["Title"] = "Team";
    Layout = "_AppLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/team/xterm.css" />
    <link rel="stylesheet" href="~/css/team/team.css" asp-append-version="true" />
}

<div class="team-page">
    <div class="container-fluid team-content">
        <div class="row h-100 gx-0">
            <div class="col-12 col-lg-9 d-flex flex-column">
                <section class="panel panel-tall">
                    <div class="problem-header">
                        <h3 class="save-note">Make sure to press run to save code!</h3>

                        <div class="problem-container">
                            <button type="button" class="problem-nav-btn" onclick="updateProblem(-1)">←</button>
                            <h3 class="problem-text">Problem 1</h3>
                            <button type="button" class="problem-nav-btn" onclick="updateProblem(1)">→</button>
                        </div>
                    </div>

                    <div class="team-editor-toolbar">
                        <label for="languages" class="team-label">Language:</label>
                        <select id="languages" name="languages" class="team-select">
                            <option value="python">Python</option>
                            <option value="java">Java</option>
                            <option value="cpp">C++</option>
                        </select>
                    </div>

                    <div id="editor" class="team-editor"></div>

                    <div class="team-action-row">
                        <button onclick="getSubmissionCode()" class="compile" type="button">▶ Run</button>
                        <button onclick="onSubmission()" id="submit" class="submit" type="button">✓ Submit</button>
                    </div>

                    <div id="submitTime" class="submit_time"></div>
                </section>

                <section class="panel panel-short mt-2">
                    <div class="panel-title">Terminal</div>
                    <div id="terminal" class="team-terminal"></div>
                </section>
            </div>

            <div class="col-12 col-lg-3 d-flex flex-column">
                <section class="panel panel-tall feedback-panel">
                    <div class="feedback-team-name">@Model.teamName.ToUpper()</div>
                    <div class="feedback-title">Feedback</div>

                    <div class="feedback-body">
                        <div class="feedback-problem-label">Current Problem:</div>
                        <div class="feedback-problem-name">Problem 1</div>

                        <div class="feedback-divider"></div>

                        <div class="feedback-section-label">Judge Feedback</div>
                        <div class="feedback-message">
                            No feedback yet for this problem.
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/team/xterm.js"></script>
    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/require.js/2.3.6/require.min.js"></script>
    <script>
        require.config({
            paths: {
                vs: "https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs"
            }
        });

        require(["vs/editor/editor.main"], function () {
            window.monacoEditor = monaco.editor.create(document.getElementById("editor"), {
                value: [
                    "# Write your solution here",
                    "",
                    "print('Hello, Code Jam')"
                ].join("\n"),
                language: "python",
                theme: "vs-dark",
                automaticLayout: true
            });
        });
    </script>
    <script src="~/js/team/config.js"></script>
    <script src="~/js/team/getSubmissionCode.js"></script>
    <script src="~/js/team/onSubmission.js"></script>
    <script src="~/js/team/updateProblem.js"></script>
    <script src="~/js/team/socket-code.js"></script>
}